cd# OpenAI 或 OpenAI 兼容服务
OPENAI_BASE_URL=https://your-openai-compatible-service.example/v1
OPENAI_API_KEY=your-openai-api-key
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# OneAPI 网关
ONEAPI_BASE_URL=https://your-oneapi-service.example/v1
ONEAPI_API_KEY=your-oneapi-api-key
ONEAPI_CHAT_MODEL=qwen-max
ONEAPI_EMBEDDING_MODEL=text-embedding-v1

# 通义千问 OpenAI 兼容模式
