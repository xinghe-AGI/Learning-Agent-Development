# 选择一个模型类型：openai、qwen、deepseek
LLM_TYPE=qwen
LLM_TEMPERATURE=0
LLM_TIMEOUT=30
LLM_MAX_RETRIES=2

# 后端服务与 WebUI 地址
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8012
WEB_HOST=127.0.0.1
WEB_PORT=7860

# 仅填写实际使用的一组模型配置；不要提交真实 Key。
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=

QWEN_BASE_URL=
QWEN_API_KEY=
QWEN_CHAT_MODEL=

DEEPSEEK_BASE_URL=
DEEPSEEK_API_KEY=
DEEPSEEK_CHAT_MODEL=
